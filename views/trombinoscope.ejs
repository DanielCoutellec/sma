<section class="section">
  <div class="container">
    <div class="page-head">
      <p class="page-kicker">L’ÉQUIPE</p>
      <h1 class="page-title">Trombinoscope</h1>
      <p class="muted page-lead">
        Les motards SMA mobilisés pour la sécurité, l’information et l’assistance sur les courses.
      </p>

      <div class="page-actions">
        <a href="/contact" class="btn btn-primary">Contacter SMA</a>
        <a href="/courses2026" class="btn btn-ghost">Voir les courses</a>
      </div>
    </div>

    <div class="slider-wrap" style="margin-top:20px;">
      <button class="slider-btn slider-btn-prev" type="button" aria-label="Précédent">‹</button>

      <div class="team-slider" id="teamSlider">
        <% (membres || []).forEach((m) => { %>
          <article class="person-card">
            <div class="avatar">
              <img
                src="<%= m.photo %>"
                alt="<%= m.nom %>"
                class="zoomable"
                data-caption="<%= m.nom %><%= m.role ? ' – ' + m.role : '' %>"
                onerror="this.onerror=null;this.src='/img/avatar-defaut.jpg';"
              />
            </div>

            <div class="person-meta">
              <h3><%= m.nom %></h3>

              <% if (m.role) { %>
                <p class="muted"><%= m.role %></p>
              <% } %>

              <% if (m.tags && m.tags.length) { %>
                <div class="person-tags">
                  <% m.tags.forEach((tag) => { %>
                    <span><%= tag %></span>
                  <% }) %>
                </div>
              <% } %>
            </div>

            <div class="person-actions">
              <span class="muted"><%= m.dept || "SMA" %></span>
             
            </div>
          </article>
        <% }) %>
      </div>

      <button class="slider-btn slider-btn-next" type="button" aria-label="Suivant">›</button>
    </div>
  </div>
</section>