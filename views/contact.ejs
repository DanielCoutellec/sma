<section class="section" id="contact">
  <div class="container">
    <div class="section-header">
      <h2>Contact</h2>
      <p class="muted">
        Pour toute demande d’accompagnement sur une course ou une saison,
        n’hésitez pas à nous contacter.
      </p>
    </div>

    <div class="contact-grid">
      <div>
        <ul class="contact-list">
          <li>
            <strong>Président</strong><br />
            Nom Prénom<br />
            Tél : 06 00 00 00 00
          </li>
          <li>
            <strong>Secrétaire</strong><br />
            Nom Prénom<br />
            Tél : 06 00 00 00 00
          </li>
          <li>
            <strong>Trésorier</strong><br />
            Nom Prénom<br />
            Tél : 06 00 00 00 00
          </li>
        </ul>

        <p>
          Retrouvez aussi les photos et comptes rendus sur notre page Facebook.
        </p>
      </div>

      <form class="contact-form" id="contactForm" method="POST" action="/contact">
        <label>
          Nom<br />
          <input type="text" name="name" required />
        </label>
        <label>
          Email<br />
          <input type="email" name="email" required />
        </label>
        <label>
          Sujet<br />
          <input type="text" name="subject" required />
        </label>
        <label>
          Message<br />
          <textarea name="message" rows="4" required></textarea>
        </label>
        <button type="submit">Envoyer</button>
        <p class="form-feedback" id="formFeedback">
          <% if (typeof success !== "undefined") { %>
            <%= success %>
          <% } %>
        </p>
      </form>
    </div>
  </div>
</section>
