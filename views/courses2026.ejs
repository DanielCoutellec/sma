<section class="section">
  <div class="container">

    <!-- HEADER -->
    <div class="page-head">
      <p class="page-kicker">CALENDRIER</p>
      <h1 class="page-title">Courses 2026</h1>
      <p class="muted page-lead">
        Planning des épreuves accompagnées par SMA.
      </p>

      <div class="page-actions">
        <a href="/contact" class="btn btn-primary">Demander une assistance</a>
        <a href="/trombinoscope" class="btn btn-ghost">Voir l’équipe</a>
      </div>
    </div>

    <!-- KPI -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <p class="kpi-label">Courses</p>
        <p class="kpi-value"><%= (courses || []).length %></p>
      </div>

      <div class="kpi-card">
        <p class="kpi-label">Zone</p>
        <p class="kpi-value">Nouvelle-Aquitaine</p>
      </div>

      <div class="kpi-card">
        <p class="kpi-label">Disponibilité</p>
        <p class="kpi-value">Sur demande</p>
      </div>
    </div>

    <!-- LISTE -->
    <% groupedCourses.forEach(function(group){ %>

      <div class="month-block">
        <div class="month-title">
          <h2><%= group.mois %></h2>
          <span><%= group.items.length %> courses</span>
        </div>

        <div class="courses-grid">
          <% group.items.forEach(function(course){ %>

            <div class="course-card">

              <div class="course-date">
                <%= course.date || "-" %>
              </div>

              <h3 class="course-name">
                <%= course.epreuve %>
              </h3>

              <div class="course-lieu">
                📍 <%= course.lieu %>
              </div>

              <div class="course-tags">
                <span class="pill pill-blue"><%= course.type || "Course" %></span>

                <span class="pill <%= (course.statut || '').toLowerCase().includes('confirm') ? 'pill-green' : 'pill-yellow' %>">
                  <%= course.statut || "Prévisionnel" %>
                </span>
              </div>

              <div class="course-actions">

                <% if (course.photos) { %>
                  <a href="/photos/<%= course.photos %>" class="btn-table">📷</a>
                <% } else { %>
                  <span class="btn-table is-disabled">📷</span>
                <% } %>

                <% if (course.classement) { %>
                  <a href="<%= course.classement %>" target="_blank" class="btn-table">🏁</a>
                <% } else { %>
                  <span class="btn-table is-disabled">🏁</span>
                <% } %>

              </div>

            </div>

          <% }) %>
        </div>
      </div>

    <% }) %>

  </div>
</section>